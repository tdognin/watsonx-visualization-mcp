{
  "name": "@tdognin/watsonx-visualization-mcp",
  "version": "1.0.0",
  "description": "MCP server for automated data visualization and analysis with IBM watsonx Orchestrate - supports 40+ chart types",
  "main": "src/mcp-server/index.js",
  "type": "module",
  "bin": {
    "watsonx-viz-mcp": "src/mcp-server/index.js"
  },
  "files": [
    "src/",
    "config/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/mcp-server/index.js",
    "dev": "node --watch src/mcp-server/index.js",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "clean": "rm -rf output/* node_modules",
    "prepare": "npm run test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tdognin/watsonx-visualization-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "watsonx",
    "orchestrate",
    "visualization",
    "charts",
    "data-analysis",
    "ibm",
    "carbon-design",
    "d3",
    "plotly"
  ],
  "author": "tdognin",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "d3": "^7.8.5",
    "docx": "^8.5.0",
    "express": "^4.18.2",
    "jsdom": "^23.0.1",
    "plotly.js-dist": "^2.27.0",
    "puppeteer": "^22.0.0"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
